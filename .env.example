# PostgreSQL
POSTGRES_USER=taskforge
POSTGRES_PASSWORD=taskforge_secret
POSTGRES_DB=taskforge
POSTGRES_HOST=taskforge-db
POSTGRES_PORT=5432

# Redis
REDIS_HOST=taskforge-redis
REDIS_PORT=6379

# Application
DATABASE_URL=postgresql+asyncpg://taskforge:taskforge_secret@taskforge-db:5432/taskforge
DATABASE_URL_SYNC=postgresql+psycopg2://taskforge:taskforge_secret@taskforge-db:5432/taskforge
CELERY_BROKER_URL=redis://taskforge-redis:6379/0
CELERY_RESULT_BACKEND=redis://taskforge-redis:6379/1

# Job processing
MAX_RETRIES=5
RETRY_BASE_DELAY=2
DLQ_QUEUE_NAME=taskforge-dlq

# Grafana
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=admin
GF_USERS_ALLOW_SIGN_UP=false
